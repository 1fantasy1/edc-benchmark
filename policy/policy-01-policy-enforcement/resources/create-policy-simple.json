{
  "@context": {
    "@vocab": "https://w3id.org/edc/v0.0.1/ns/",
    "edc": "https://w3id.org/edc/v0.0.1/ns/",
    "odrl": "http://www.w3.org/ns/odrl/2/"
  },
  "@type": "PolicyDefinition",
  "@id": "{{POLICY_ID}}",
  "policy": {
    "@type": "odrl:Set",
    "odrl:permission": [
      {
        "odrl:action": {
          "@id": "odrl:use"
        },
        "odrl:constraint": {
          "odrl:leftOperand": "https://w3id.org/edc/v0.0.1/ns/location",
          "odrl:operator": {
            "@id": "odrl:eq"
          },
          "odrl:rightOperand": {
            "@value": "eu"
          }
        }
      }
    ]
  }
}
